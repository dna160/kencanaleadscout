{
  "name": "@kencana/server",
  "version": "1.0.0",
  "description": "Fastify service hosting the scraper + call cockpit + champion dashboard surfaces.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "seed": "tsx src/db/seedLeads.ts",
    "migrate": "tsx src/db/migrate.ts",
    "dedup": "tsx src/db/dedupeLeads.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.1",
    "@kencana/core": "workspace:*",
    "fastify": "^5.1.0",
    "postgres": "^3.4.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
