# ---- Server ----
# Injected by Railway in production. Locally defaults to 8080.
PORT=8080

# ---- Scraper tunables (Part A) ----
CONCURRENCY=10
REQUEST_TIMEOUT_MS=12000
MAX_PAGES_PER_SITE=4
# Max upload size in bytes (default 15MB).
MAX_UPLOAD_BYTES=15728640

# ---- Database (Part B) ----
# Injected by the Railway Postgres plugin in production.
# Local example (matches docker-compose.yml):
DATABASE_URL=postgres://kencana:kencana@localhost:5432/leadscout

# ---- Logging ----
# info | debug | warn | error
LOG_LEVEL=info
